{
  "name": "mcp-server-sketchfab",
  "version": "1.0.0",
  "description": "Model Context Protocol server for searching, browsing, and downloading 3D models from Sketchfab via Cursor, Claude Desktop, and other MCP clients.",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "mcp-server-sketchfab": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sketchfab",
    "3d",
    "3d-models",
    "3d-assets",
    "gltf",
    "glb",
    "usdz",
    "cursor",
    "claude",
    "ai-assistant",
    "stdio"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.18.1",
    "yargs": "^18.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.15.0",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
